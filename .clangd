CompileFlags:
  # Treat .ino files as C++ (Arduino convention)
  Add:
    - "-xc++"
    - "-std=c++17"
    - "-ferror-limit=0"

    # ---- Arduino / ESP32 defines ----
    - "-DARDUINO=10819"
    - "-DESP32"
    - "-DARDUINO_ARCH_ESP32"
    - "-DARDUINO_ESP32_DEV"
    - "-DF_CPU=240000000L"
    - "-DHAVE_CONFIG_H"
    - "-DCONFIG_IDF_TARGET_ESP32=1"
    - "-DSOC_UART_HP_NUM=3"
    - "-DSOC_UART_NUM=3"

    # ---- ESP32 Arduino Core ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/cores/esp32"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/variants/doitESP32devkitV1"

    # ---- ESP32 Built-in Libraries ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/WiFi/src"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/Wire/src"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/SPI/src"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/FS/src"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/Network/src"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/NetworkClientSecure/src"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/WebServer/src"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/Ticker/src"

    # ---- ESP-IDF SDK Config (critical: many headers depend on sdkconfig.h) ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/dio_qspi/include"

    # ---- ESP-IDF SDK Headers (top-level includes) ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_common/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_hw_support/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_system/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_event/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_wifi/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_netif/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_timer/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_rom/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_rom/esp32"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_partition/include"

    # ---- HAL / SOC / Driver ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/hal/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/hal/esp32/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/soc/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/soc/esp32/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/driver/deprecated"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/driver/i2c/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/driver/touch_sensor/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_gpio/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_uart/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_ledc/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_spi/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_i2c/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_rmt/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_gptimer/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_pcnt/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_driver_tsens/include"

    # ---- FreeRTOS ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/freertos/FreeRTOS-Kernel/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/freertos/FreeRTOS-Kernel/portable/xtensa/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/freertos/esp_additions/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/freertos/config/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/freertos/config/xtensa/include"

    # ---- Networking (lwIP) ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/lwip/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/lwip/lwip/src/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/lwip/port/include"

    # ---- Other SDK Components ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/newlib/platform_include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/heap/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/log/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_ringbuf/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/nvs_flash/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_phy/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_coex/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_netif_stack/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/wpa_supplicant/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/wpa_supplicant/port/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/esp_pm/include"

    # ---- Xtensa Toolchain C Library Headers ----
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp-x32/2511/xtensa-esp-elf/include"
    - "-I/Users/scroobrz/Library/Arduino15/packages/esp32/tools/esp-x32/2511/xtensa-esp-elf/include/c++/14.2.0"

    # ---- Project-Local Libraries (your Arduino/libraries/) ----
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/Adafruit_NeoPixel"
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/Adafruit_BusIO"
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/Adafruit_PWM_Servo_Driver_Library"
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/Seeed_PCA9685-master"
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/WebSockets/src"
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/firmware_V4_config"
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/firmware_V4_debug"
    - "-I/Users/scroobrz/SDP-Open-Octave/Arduino/libraries/firmware_V4_sequences"

  Remove:
    - "-W*"

Diagnostics:
  # Suppress "file not found" errors from deep ESP-IDF transitive includes
  # that we haven't enumerated above. This keeps real syntax checks active
  # (missing semicolons, type mismatches, wrong args, typos) while hiding
  # noise from the long tail of ESP-IDF internal headers.
  Suppress:
    - "pp_file_not_found"
    - "pp_error_opening_file"
    - "typecheck_convert_incompatible"  # WebSocketServerEvent false positive (std::function unresolved)
  ClangTidy:
    Remove: "*"
