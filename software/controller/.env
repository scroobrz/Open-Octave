APP_PORT=3000
WS_PORT=81

# WiFi hotspot — only used on Linux (Pi Zero deployment)
# On macOS dev, use USB serial instead
HOTSPOT_ENABLED=false
HOTSPOT_SSID=Open Octave
HOTSPOT_PASSWORD=oop321321

# USB serial — two-module demo setup
# Comma-separated list of serial ports (one per USB-connected module)
SERIAL_PORTS=/dev/cu.usbserial-110,/dev/cu.usbserial-120

# Single port fallback (used if SERIAL_PORTS is not set)
# SERIAL_PORT=/dev/cu.usbserial-10
