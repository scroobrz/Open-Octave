# Open Octave Controller — Environment Configuration
# Copy this file to .env and adjust for your setup.

APP_PORT=3000
WS_PORT=81

# WiFi hotspot — only used on Linux (Pi Zero deployment)
# On macOS dev, use USB serial instead
HOTSPOT_ENABLED=false
HOTSPOT_SSID=Open Octave
HOTSPOT_PASSWORD=changeme

# USB serial — comma-separated list of serial ports (one per USB-connected module)
# Leave empty or comment out for WiFi-only mode.
# macOS example:  /dev/cu.usbserial-120,/dev/cu.usbserial-130
# Linux example:  /dev/ttyUSB0,/dev/ttyUSB1
# SERIAL_PORTS=
