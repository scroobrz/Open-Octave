{
  "name": "open-octave-controller",
  "version": "1.0.0",
  "description": "Proxy server for Open Octave ESP32 — WebSocket & Serial",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:laptop": "node server.js",
    "dev": "nodemon server.js",
    "mock:esp32": "node mock_esp32_ws.js",
    "test": "vitest run --globals",
    "test:watch": "vitest --globals",
    "test:coverage": "vitest run --globals --coverage --coverage.exclude=mock_esp32_ws.js"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "serialport": "^13.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.1.0",
    "supertest": "^7.1.1",
    "vitest": "^3.2.4"
  }
}
